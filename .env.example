# ── GlobalTelco Server Configuration ────────────────────────────────────────

# Server bind address and port
GT_HOST=0.0.0.0
GT_PORT=3001

# JWT secret for authentication
# Generate with: openssl rand -base64 32
GT_JWT_SECRET=CHANGE_ME_IN_PRODUCTION

# JWT token expiry (seconds)
GT_ACCESS_TOKEN_EXPIRY=3600
GT_REFRESH_TOKEN_EXPIRY=2592000

# Default game world settings
GT_DEFAULT_WORLD=Default World
GT_MAX_PLAYERS=8

# PostgreSQL connection (Neon DB)
# Not required for local dev — server uses in-memory stores by default
# For production: set in /opt/globaltelco/.env on the Oracle Cloud server
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require  # Replace with your connection string

# Admin API key (for /api/admin/* endpoints)
# Required in production — admin endpoints return 503 if unset
ADMIN_KEY=

# Logging level (trace, debug, info, warn, error)
RUST_LOG=gt_server=info,tower_http=info

# ── Cloudflare R2 Object Storage (Optional) ─────────────────────────────────
# When configured, world snapshots and cloud saves are stored in R2 instead
# of PostgreSQL BYTEA blobs. Falls back to DB blobs when not set.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=globaltelco

# ── Frontend Configuration ──────────────────────────────────────────────────

# API server URL (used by frontend in multiplayer mode)
# For production: set in Vercel project environment variables
PUBLIC_API_URL=http://localhost:3001
PUBLIC_WS_URL=ws://localhost:3001/ws

# CORS — allowed frontend origin (restrict in production)
# CORS_ORIGIN=https://globaltelco.online

# ── Production Deployment ──────────────────────────────────────────────────
#
# Game server (Oracle Cloud Free Tier):
#   Deploy with: ORACLE_IP=159.54.188.149 ./deploy/deploy.sh
#   Domain: server.globaltelco.online (Cloudflare proxied, SSL Flexible)
#   Server .env at: /opt/globaltelco/.env
#
# Frontend (Vercel):
#   Deploys automatically on push to main (connected to GitHub).
#   Custom domain: globaltelco.online (Cloudflare DNS → Vercel)
#   Set env vars in Vercel dashboard: PUBLIC_API_URL, PUBLIC_WS_URL
#
# DNS (Cloudflare):
#   globaltelco.online → 76.76.21.21 (Vercel, DNS-only)
#   server.globaltelco.online → 159.54.188.149 (Oracle, Proxied)
#   SSL mode: Flexible, WebSockets: On
#
# Neon DB (PostgreSQL):
#   Connection string from Neon console → Connection Details.
#   Migrations run automatically on server startup.
